model Lab {
  id             Int      @id @default(autoincrement())
  name           String
  email          String
  phone          String
  registrationNo String?
  address1       String?
  address2       String?
  city           String
  state          String
  country        String
  postalCode     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users        User[]
  branches     Branch[]
  activityLogs ActivityLog[]
  patients     Patient[]
  tests        Test[]
  bookings     Booking[]
  reports      Report[]
}
