model Permission {
    id              String           @id @default(cuid())
    name            String           @unique
    rolePermissions RolePermission[]
}

model RolePermission {
    id           String     @id @default(cuid())
    role         String
    permissionId String
    permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@unique([role, permissionId])
}
