model User {
  id                       Int       @id @default(autoincrement())
  refId                    String?
  name                     String
  email                    String    @unique
  phone                    String
  role                     String // OWNER, STAFF, BRANCH_MANAGER, TECHNICIAN, RECEPTIONIST, SUPER_ADMIN
  gender                   String? // MALE, FEMALE, OTHER
  photo                    String?
  status                   String?   @default("ACTIVE") // ACTIVE, INACTIVE, INVITED, SUSPENDED
  password                 String
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  inviteToken              String?
  inviteTokenExpires       DateTime?
  jwtToken                 String?
  jwtTokenExpires          DateTime?
  isTempPassword           Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  labId Int
  lab   Lab @relation(fields: [labId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  activityLogs ActivityLog[]
}
