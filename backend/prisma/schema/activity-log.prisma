model ActivityLog {
  id       Int     @id @default(autoincrement())
  action   String
  entity   String
  message  String?
  metadata String?

  performedById Int
  performedBy   User @relation(fields: [performedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  labId Int
  lab   Lab @relation(fields: [labId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  testId Int?
  test   Test? @relation(fields: [testId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  bookingId Int?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  reportId Int?
  report   Report? @relation(fields: [reportId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
