model Report {
    id           Int      @id @default(autoincrement())
    reportId     String?
    testResults  String?  @db.NVarChar(Max)
    status       String?  @default("REPORTED") //DRAFT | SUSPENDED | REPORTED
    aiSuggestion String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    activityLogs ActivityLog[]

    labId Int
    lab   Lab @relation(fields: [labId], references: [id], onDelete: NoAction, onUpdate: NoAction)

    branchId Int?
    branch   Branch? @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)

    bookingId Int?
    booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

    patientId Int?
    patient   Patient? @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
