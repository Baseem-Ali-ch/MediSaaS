model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  phone     String
  address   String?
  city      String
  state     String
  country   String
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  labId Int
  lab   Lab @relation(fields: [labId], references: [id])

  users User[]
}